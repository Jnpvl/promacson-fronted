# Copia a .env.local: cp .env.example .env.local
# En dev sin .env.local se usa http://localhost:4000 por defecto (admin requiere backend).
NEXT_PUBLIC_API_URL=http://localhost:4000
API_URL=http://localhost:4000

# Origen público del front (canónicas, Open Graph). Sin esto en dev: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
